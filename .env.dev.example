# Haven — DEV environment variables (template)
#
# The single shared dev environment (one `dev` branch → one Railway/Vercel deploy).
# Mirrors .env.example with dev-isolated values. Set these in the dev Railway
# project (backend / mcp-server) and the dev Vercel project (frontend) — never in
# code. Every secret here MUST differ from production.
#
# Key isolation rules:
#   - Separate Postgres from prod (payment product — never share a DB).
#   - Dev-only JWT_SECRET and RELAYER_PRIVATE_KEY (cross-env token confusion + no
#     real funds at risk).
#   - Prefer TESTNETS for dev RPC so WIP code can't move real funds on mainnet.

# Backend
PORT=3001
# Dev Postgres — a separate Railway managed instance, NOT the prod DB.
DATABASE_URL=postgresql://haven:haven@dev-postgres-host:5432/haven_dev

# Blockchain — prefer testnets for dev (Gnosis Chiado + Base Sepolia).
# Swap to mainnet RPCs only if a test genuinely needs mainnet state.
RPC_URL=https://rpc.chiadochain.net
RPC_URL_BASE=https://sepolia.base.org

# Auth — dev-only secret, must differ from prod.
JWT_SECRET=generate_a_dev_only_secret

# APIs (can reuse prod keys or use separate dev keys)
GNOSISSCAN_API_KEY=your_api_key_from_gnosisscan.io
BASESCAN_API_KEY=your_api_key_from_basescan.org
COINGECKO_API_KEY=your_api_key_from_coingecko.com

# Frontend — point at the dev backend / dev mcp-server, dev WalletConnect project.
# The dev frontend has NO permanent URL — it's a per-PR Vercel preview link that
# changes on every deployment; FRONTEND_URL only feeds backend-built links (e.g.
# the Fortnox redirect). Set it to the current preview URL when one is needed.
# CONFIRM the dev frontend URL in Vercel — haven-dev.vercel.app is a DIFFERENT app
# ("HAVEN Project" Vite SPA), not Haven's Next.js dashboard.
#
# NOTE: there are TWO Railway backends — the LIVE dev one is havenbackend-dev-8b95
# (verified). `dev-backend.up.railway.app` is a STALE DUPLICATE that still responds
# with ~24-day-old code; do NOT use it (it caused real confusion — see #585/#595).
FRONTEND_URL=https://CONFIRM-dev-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://havenbackend-dev-8b95.up.railway.app
# CONFIRM the full hash in Railway — the dev MCP is haven-ai-hosted-mcp-dev-<hash>.
NEXT_PUBLIC_HAVEN_MCP_URL=https://haven-ai-hosted-mcp-dev-CONFIRM.up.railway.app/v1
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_dev_walletconnect_project_id
# Shows the "DEV" badge in the app header (see components/EnvBadge.tsx).
NEXT_PUBLIC_HAVEN_ENV=dev

# Haven API URL (scripts / mcp-server / demo-merchant → internal dev backend URL)
HAVEN_API_URL=https://havenbackend-dev-8b95.up.railway.app

# Dev demo-merchant — x402 settlement target for QA (#575). Verified online.
QA_DEMO_MERCHANT_URL=https://demo-merchant-dev-84e4.up.railway.app

# Relayer — DEV EOA, funded with minimal testnet gas. Never the prod relayer key.
# Generate one: node -e "const{ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log('Address:',w.address);console.log('Key:',w.privateKey)"
RELAYER_PRIVATE_KEY=your_dev_relayer_private_key

# Fortnox bookkeeping integration (optional — disabled unless all three are set).
# Use a separate dev Fortnox app + redirect if testing the feed on dev.
FORTNOX_CLIENT_ID=your_dev_fortnox_client_id
FORTNOX_CLIENT_SECRET=your_dev_fortnox_client_secret
FORTNOX_REDIRECT_URI=https://havenbackend-dev-8b95.up.railway.app/accounting/fortnox/callback

# Feature flags — keep dark unless a dev test exercises them (same defaults as prod).
CATALOG_DISCOVERY_ENABLED=false
HAVEN_FEE_ENABLED=false
HAVEN_LEGACY_BOOKKEEPING_ENABLED=false
HAVEN_HOSTED=false
HAVEN_REPORTING_FEED_ENABLED=false
