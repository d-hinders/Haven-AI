# Backend
PORT=3001
DATABASE_URL=postgresql://haven:haven@localhost:5432/haven

# Blockchain
RPC_URL=https://rpc.gnosischain.com
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org

# Chains this environment serves account deploys on (#679). Comma-separated;
# UNSET = all supported. Onboarding offers only these and a non-served chain is
# rejected with a clear message instead of a confusing "relayer unfunded".
# Prod: 8453,84532 (once a Sepolia relayer is funded); dev: 84532.
# HAVEN_DEPLOY_CHAIN_IDS=8453,84532

# Auth
JWT_SECRET=change_me_in_production

# APIs
GNOSISSCAN_API_KEY=your_api_key_from_gnosisscan.io
BASESCAN_API_KEY=your_api_key_from_basescan.org
COINGECKO_API_KEY=your_api_key_from_coingecko.com

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_HAVEN_MCP_URL=https://haven-ai-production-5953.up.railway.app/v1
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_from_cloud.walletconnect.com
# Environment indicator. Leave unset (or "production") on prod; set to "dev" on
# the dev deploy to show a "DEV" badge in the app header. Build-time inlined.
# NEXT_PUBLIC_HAVEN_ENV=
# Default onboarding chain (#615). Unset → Base mainnet (8453); set to 84532 to
# default new accounts to Base Sepolia (the dev deploy does this). Both chains
# stay selectable (#622). Build-time inlined — set per Vercel scope.
# NEXT_PUBLIC_HAVEN_CHAIN_ID=

# Haven API URL (used by scripts — backend runs on this port)
HAVEN_API_URL=http://localhost:3001

# Relayer — EOA that pays gas for agent transactions (needs small xDAI balance)
# Generate one: node -e "const{ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log('Address:',w.address);console.log('Key:',w.privateKey)"
RELAYER_PRIVATE_KEY=your_relayer_private_key
# Per-chain relayer override (#640/#678): RELAYER_PRIVATE_KEY_<chainId> submits
# Safe deploys / exec / allowance transfers on that chain, falling back to the key
# above. Lets a multichain backend run an isolated, testnet-only Base Sepolia
# relayer separate from the mainnet one (prod).
# RELAYER_PRIVATE_KEY_84532=a_dedicated_testnet_only_relayer_key

# Fortnox bookkeeping integration (optional — disabled unless all three are set)
# Register an app at https://developer.fortnox.se and request the Bookkeeping scope.
# FORTNOX_REDIRECT_URI must match the redirect registered there (the backend
# callback, e.g. https://your-backend/accounting/fortnox/callback).
FORTNOX_CLIENT_ID=your_fortnox_client_id
FORTNOX_CLIENT_SECRET=your_fortnox_client_secret
FORTNOX_REDIRECT_URI=https://your-backend/accounting/fortnox/callback

# Merchant-catalog auto-discovery from the x402 Bazaar (#473). Off by default;
# set to "true" to let the hourly catalog job pull candidates from the Bazaar
# and probe-verify them before listing. CATALOG_DISCOVERY_URL is optional.
CATALOG_DISCOVERY_ENABLED=false
# CATALOG_DISCOVERY_URL=https://api.cdp.coinbase.com/platform/v2/x402/discovery/resources

# Platform fee module (#386). Dark by default — leave unset/false. When false
# the per-transaction fee is always zero and no funds move.
HAVEN_FEE_ENABLED=false

# Legacy asserting bookkeeping (epic #462). Dark by default — superseded by the
# non-asserting reporting feed (#491). Leave false to keep SIE export + finished
# voucher push gated off.
HAVEN_LEGACY_BOOKKEEPING_ENABLED=false

# Reporting feed (epic #491) — hosted-only paid add-on. Inert unless ALL hold:
# HAVEN_HOSTED=true (managed deployment), this flag on, and the account has the
# 'reporting_feed' entitlement. Env alone can never enable it on a self-host.
HAVEN_HOSTED=false
HAVEN_REPORTING_FEED_ENABLED=false

# Agent testing — fill these in after creating an agent in the Haven dashboard
AGENT_API_KEY=sk_agent_your_key_from_dashboard
DELEGATE_PRIVATE_KEY=your_delegate_private_key
PAYMENT_TO=0x_recipient_address

# Claude agent demo (optional — only needed for npm run agent:demo)
ANTHROPIC_API_KEY=sk-ant-your_key_from_console.anthropic.com
