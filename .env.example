# Backend
PORT=3001
DATABASE_URL=postgresql://haven:haven@localhost:5432/haven

# Blockchain
RPC_URL=https://rpc.gnosischain.com

# Auth
JWT_SECRET=change_me_in_production

# APIs
GNOSISSCAN_API_KEY=your_api_key_from_gnosisscan.io
COINGECKO_API_KEY=your_api_key_from_coingecko.com

# Frontend
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_from_cloud.walletconnect.com

# Haven API URL (used by scripts — backend runs on this port)
HAVEN_API_URL=http://localhost:3001

# Relayer — EOA that pays gas for agent transactions (needs small xDAI balance)
# Generate one: node -e "const{ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log('Address:',w.address);console.log('Key:',w.privateKey)"
RELAYER_PRIVATE_KEY=your_relayer_private_key

# Agent testing — fill these in after creating an agent in the Haven dashboard
AGENT_API_KEY=sk_agent_your_key_from_dashboard
DELEGATE_PRIVATE_KEY=your_delegate_private_key
PAYMENT_TO=0x_recipient_address

# Claude agent demo (optional — only needed for npm run agent:demo)
ANTHROPIC_API_KEY=sk-ant-your_key_from_console.anthropic.com
