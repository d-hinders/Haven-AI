{
  "name": "@haven/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm --prefix ../sdk run build && tsc",
    "typecheck": "npm --prefix ../sdk run build && tsc --noEmit",
    "start": "node dist/index.js",
    "test": "npm --prefix ../sdk run build && vitest run",
    "test:watch": "npm --prefix ../sdk run build && vitest",
    "test:loop": "vitest run src/loop-harness",
    "test:payment": "tsx scripts/test-payment-flow.ts",
    "agent:demo": "tsx scripts/agent-payment-demo.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.1.0",
    "@haven_ai/sdk": "*",
    "@rhinestone/module-sdk": "^0.4.0",
    "@safe-global/protocol-kit": "^5.1.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.0",
    "ethereum-cryptography": "^2.2.1",
    "ethers": "^6.13.0",
    "fastify": "^5.8.5",
    "pg": "^8.13.0",
    "viem": "^2.54.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
