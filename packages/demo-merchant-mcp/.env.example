# Required: Base wallet address that receives USDC payments
MERCHANT_ADDRESS=0xYOUR_MERCHANT_ADDRESS

# Public URL where this service is deployed (used in 402 responses + invoice resource URLs)
BASE_URL=https://your-demo-merchant.railway.app

# HTTP port (Railway sets this automatically)
PORT=3456

# Chain selection: 8453 = Base mainnet (default), 84532 = Base Sepolia testnet
# MERCHANT_CHAIN_ID=84532

# Experimental ERC-7710 x402 rail (#747, epic #452) — TESTNET-ONLY.
# When set to 1 (requires MERCHANT_CHAIN_ID=84532; startup fails otherwise), the
# 402 challenge additionally advertises assetTransferMethod 'erc7710' so a smart
# account can pay the merchant directly via a signed delegation, verified by
# simulating redeemDelegations. The SETTLEMENT_PRIVATE_KEY account is the
# redeemer: delegations with a redeemer caveat must name it.
# MERCHANT_X402_ERC7710=1
