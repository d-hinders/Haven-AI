{
  "name": "@haven_ai/mcp-server",
  "version": "0.1.11-alpha.0",
  "description": "Hosted, keyless Haven MCP server — constructs and relays payments over Streamable HTTP. Never holds the delegate key; the edge signs.",
  "type": "module",
  "bin": {
    "haven-mcp-server": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm --prefix ../sdk run build && tsup",
    "start": "node dist/cli.js",
    "test": "npm --prefix ../sdk run build && npm --prefix ../signer run build && vitest run",
    "typecheck": "npm --prefix ../sdk run build && npm --prefix ../signer run build && tsc --noEmit"
  },
  "keywords": [
    "haven",
    "mcp",
    "hosted",
    "agent",
    "payments",
    "non-custodial"
  ],
  "license": "MIT",
  "dependencies": {
    "@haven_ai/sdk": "0.1.11-alpha.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@haven_ai/signer": "0.1.11-alpha.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "viem": "^2.0.0"
  }
}
