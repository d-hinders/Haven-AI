{
  "name": "@haven_ai/sdk",
  "version": "0.1.17-alpha.0",
  "description": "TypeScript SDK for Haven — agent wallet infrastructure",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "haven",
    "agent",
    "wallet",
    "payments",
    "safe",
    "gnosis",
    "web3",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-hinders/Haven-AI.git",
    "directory": "packages/sdk"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "viem": "^2.51.0",
    "x402": "^1.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
